{
    "name": "bleeld/think-smart-event",
    "description": "ThinkPHP 智能事件订阅系统扩展包",
    "type": "library",
    "keywords": ["thinkphp", "event", "subscriber"],
    "homepage": "https://github.com/yourname/think-smart-event",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": ">=8.0",
        "topthink/framework": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "think\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "think\\Tests\\": "tests/"
        }
    },
    "extra": {
        "think": {
            "services": [
                "bleeld\\SmartEvent\\EventService"
            ]
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@copy-config"
        ],
        "post-update-cmd": [
            "@copy-config"
        ],
        "copy-config": [
            "if [ ! -f './config/smart_event.php' ]; then cp './vendor/bleeld/think-smart-event/src/config/smart_event.php' './config/smart_event.php'; fi"
        ]
    }
}